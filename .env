# YES I commited a .env file, NO it has nothing important in it. All .env files with important stuff arent commited
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWD=postgres

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWD=redis

JWT_ACCESS_SECRET=deadlockAccess # This should be a randomly generated strong secret however for sake of reproducability it is this
JWT_REFRESH_SECRET=deadlockRefresh # And same with this
JWT_ACCESS_EXPIRY_HRS=1
JWT_REFRESH_EXPIRY_DAYS=30

COOKIE_SECRET=deadlockCookies # This should also be more secure

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8888
ALLOWED_REDIRECT_PATHS=/,/dashboard,/profile

DEFAULT_FRONTEND_URL=http://localhost:5173
DEFAULT_BACKEND_URL=http://localhost:8888

APP_PROTOCOL=https
APP_DOMAIN=localhost
APP_PORT=8888
